OC_CHAT_PROVIDER=hermes
HERMES_AUTOSTART=1
HERMES_RUNTIME_INSTALL=1
HERMES_BUNDLED_SOURCE=
HERMES_HOME=
AGENT_BROWSER_HOME=
HERMES_EXECUTABLE_PATH=
HERMES_EXECUTABLE_ARGS_JSON=
HERMES_BASE_URL=http://127.0.0.1:8642
HERMES_HEALTH_PATH=/health
HERMES_HEALTH_INTERVAL_MS=5000
HERMES_HEALTH_FAILURE_THRESHOLD=3
HERMES_RESTART_BASE_DELAY_MS=1000
HERMES_RESTART_MAX_DELAY_MS=30000
HERMES_STOP_TIMEOUT_MS=5000
HERMES_MODEL=glm-5.1
HERMES_INFERENCE_PROVIDER=custom
# Local API-server key. Required for Hermes session continuity.
HERMES_API_KEY=oc-world-local-key
API_SERVER_KEY=oc-world-local-key

ANTHROPIC_AUTH_TOKEN=
# BigModel Claude-compatible endpoint, used when OC_CHAT_PROVIDER=legacy
ANTHROPIC_BASE_URL=https://open.bigmodel.cn/api/anthropic
ANTHROPIC_DEFAULT_HAIKU_MODEL=glm-5.1
# Hermes custom provider can reuse the same BigModel-compatible endpoint.
OPENAI_API_KEY=
CUSTOM_BASE_URL=https://open.bigmodel.cn/api/anthropic
OC_DEMO_FORCE_MOCK_LLM=0
OC_DEMO_FORCE_MOCK_AIRJELLY=0

# Hermes agent tools. Configure at least one web backend for web_search/web_extract.
OC_HERMES_WEB_BACKEND=firecrawl
FIRECRAWL_API_KEY=
FIRECRAWL_API_URL=
TAVILY_API_KEY=
EXA_API_KEY=
PARALLEL_API_KEY=
BROWSER_USE_API_KEY=
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# Text-to-speech. If Doubao is not configured, the app falls back to browser speechSynthesis.
OC_TTS_PROVIDER=doubao
DOUBAO_TTS_APP_ID=
DOUBAO_TTS_ACCESS_TOKEN=
DOUBAO_TTS_ENDPOINT=https://openspeech.bytedance.com/api/v1/tts
DOUBAO_TTS_CLUSTER=volcano_tts
DOUBAO_TTS_VOICE_TYPE=BV700_streaming
DOUBAO_TTS_ENCODING=mp3
DOUBAO_TTS_RATE=24000
DOUBAO_TTS_SPEED_RATIO=0.96
DOUBAO_TTS_VOLUME_RATIO=1
DOUBAO_TTS_PITCH_RATIO=1

# Image generation (Marswave)
MARSWAVE_API_KEY=
